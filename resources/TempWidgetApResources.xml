<resources>
<properties>
	<property id="T0ID" type="number">0</property>
	<property id="T0Label" type="string">Tempe1</property>
	<property id="Timeout" type="number">1200</property>
	<property id="WhiteBG" type="boolean">Dbg</property>
	<property id="Dbg" type="boolean">Dbg</property>
    <property id="Btry" type="boolean">Battery</property>
</properties>

<settings>
    <setting propertyKey="@Properties.Timeout" title="@Strings.TimeoutTitle">
        <settingConfig type="numeric" min="2"/>
    </setting>
    <setting propertyKey="@Properties.T0Label" title="@Strings.T0LabelTitle">
        <settingConfig type="alphaNumeric"  maxLength="12"/>
    </setting>
    <setting propertyKey="@Properties.T0ID" title="@Strings.T0IDTitle">
        <settingConfig type="numeric" min="-2"/>
    </setting>
    <setting propertyKey="@Properties.WhiteBG" title="@Strings.WhiteBGTitle">
        <settingConfig type="boolean"/>
    </setting>
    <setting propertyKey="@Properties.Dbg" title="@Strings.DbgTitle">
        <settingConfig type="boolean"/>
    </setting>
    <setting propertyKey="@Properties.Btry" title="@Strings.BtryTitle">
        <settingConfig type="boolean"/>
    </setting>

</settings>

</resources>